#!/usr/bin/env bash
# Launch an AI-paired PR review inside one nvim: :PrReviewStart opens diffview, spawns the
# Claude /peer-review session as a plugin-owned bottom-split terminal, and starts the review.
# Run from inside a clone of the PR's repo — :PrReviewStart's cross-repo guard enforces the
# match, and validates the argument (a GitHub PR URL, or a bare PR number inside the repo).
# No tmux: Claude now runs as an in-nvim terminal, nudged over its channel.
set -euo pipefail

[[ $# -eq 1 ]] || { echo "usage: checkout-pr-review <github-pr-url | pr-number>" >&2; exit 2; }

exec nvim -c "PrReviewStart $1"
